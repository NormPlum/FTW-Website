{{ range $movie := hugo.Data.movies }}
  {{ $params := dict
    "id" $movie.id
    "runtime" $movie.runtime
    "genres" $movie.genres
  }}

  {{ $page := dict
    "kind" "page"
    "title" $movie.title
    "dates" (dict "date" (time $movie.date))
    "params" $params
    "path" (lower $movie.id)
  }}

  {{ $.AddPage $page }}
{{ end }}
