{{ range $channel := hugo.Data.channels }}
  {{ $params := dict
    "id" $channel.id
    "videos" (index hugo.Data.channels $channel.id "videos" | len)
  }}

  {{ $page := dict
    "kind" "page"
    "title" $channel.title
    "dates" (dict "date" (time $channel.date))
    "params" $params
    "slug" $channel.id
    "path" $channel.id
  }}

  {{ $.AddPage $page }}
{{ end }}
